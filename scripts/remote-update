#!/usr/bin/env bash
# scripts/deploy
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <host> [user@ip-or-hostname]"
  echo "Example: $0 desktop"
  echo "         $0 <host> user@1.2.3.4"
  exit 1
fi

HOST="$1"
TARGET="${2:-}"

if [[ -z "$TARGET" ]]; then
  echo "Rebuilding $HOST locally..."
  sudo nixos-rebuild switch --flake ".#$HOST"
else
  echo "Deploying $HOST to $TARGET..."
  nixos-rebuild switch \
    --flake ".#$HOST" \
    --target-host "$TARGET" \
    --sudo
fi
